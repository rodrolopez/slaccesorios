@hostname = localhost
@port = 5212
@host = http://{{hostname}}:{{port}}

### 1. Iniciar Sesión en Yuyo Dev
POST {{host}}/api/Auth/login
Content-Type: application/json

{
  "email": "yuyo@yuyodev.com",
  "password": "MasterYuyo2026!"
}

> {%
    // Esto guarda el token automáticamente sin que tengas que copiar y pegar nada
    client.global.set("auth_token", response.body.token);
%}

