@page "/orders"
@using YuyoDev.AdminPanel.Models
@using YuyoDev.AdminPanel.Services
@inject OrderApiService OrderService
@inject ISnackbar Snackbar

<MudText Typo="Typo.h4" Class="mb-4">Gestión de Órdenes</MudText>

<MudTable ServerData="ServerReload" Dense="true" Hover="true" @ref="table">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Últimas Ventas</MudText>
        <MudSpacer />
    </ToolBarContent>
    <HeaderContent>
        <MudTh>ID Orden</MudTh>
        <MudTh>Fecha</MudTh>
        <MudTh>Cliente (ID)</MudTh>
        <MudTh>Total</MudTh>
        <MudTh>Estado</MudTh>
        <MudTh>Acciones</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="ID">@context.Id.ToString().Substring(0, 8)</MudTd>
        <MudTd DataLabel="Fecha">@context.CreatedAt.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</MudTd>
        <MudTd DataLabel="Cliente">@context.UserId</MudTd>
        <MudTd DataLabel="Total">$@context.TotalAmount.ToString("N2")</MudTd>
        <MudTd DataLabel="Estado">
            <MudChip T="string" Color="@GetStatusColor(context.Status)" Size="Size.Small">@context.Status</MudChip>
        </MudTd>
        <MudTd DataLabel="Acciones">
            <MudIconButton Icon="@Icons.Material.Filled.Visibility" Color="Color.Info" Size="Size.Small" />
        </MudTd>
    </RowTemplate>
    <NoRecordsContent>
        <MudText>No hay órdenes registradas.</MudText>
    </NoRecordsContent>
    <LoadingContent>
        <MudText>Cargando ventas...</MudText>
    </LoadingContent>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {
    private MudTable<OrderDto> table = null!;

    private async Task<TableData<OrderDto>> ServerReload(TableState state, CancellationToken token)
    {
        try
        {
            var result = await OrderService.GetOrdersAsync(state.Page + 1, state.PageSize);
            return new TableData<OrderDto>() { TotalItems = result.TotalCount, Items = result.Items };
        }
        catch (Exception)
        {
            Snackbar.Add("Error al cargar las órdenes.", Severity.Error);
            return new TableData<OrderDto>() { TotalItems = 0, Items = new List<OrderDto>() };
        }
    }

    private Color GetStatusColor(string status) => status.ToLower() switch
    {
        "paid" => Color.Success,
        "pending" => Color.Warning,
        "shipped" => Color.Info,
        _ => Color.Default
    };
}